{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily Stories",
  "type": "object",
  "required": ["date", "stories"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "stories": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "headline", "hook", "body", "image", "links", "tags", "readingTime", "sources"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}-\\d{3}$"
          },
          "headline": { "type": "string", "minLength": 10 },
          "hook": { "type": "string", "minLength": 20 },
          "body": { "type": "string", "minLength": 50 },
          "image": {
            "type": "object",
            "required": ["url", "alt", "credit", "creditUrl"],
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "alt": { "type": "string" },
              "credit": { "type": "string" },
              "creditUrl": { "type": "string", "format": "uri" }
            }
          },
          "links": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["title", "url"],
              "properties": {
                "title": { "type": "string" },
                "url": { "type": "string", "format": "uri" }
              }
            }
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "readingTime": { "type": "string" },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
